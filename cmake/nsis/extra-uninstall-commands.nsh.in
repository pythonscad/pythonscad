; Unregister file associations scope-aware, mirroring the install logic.
; $InstallMode: 1 = all users (HKCR), 0 = current user (HKCU). Both branches use
; the same pattern: remove ONLY the values/keys we wrote. Never DeleteRegKey on
; the extension key itself — it may contain subkeys (OpenWithProgids,
; OpenWithList, etc.) or values written by other programs that we must not
; touch. mingw-file-association.nsh's ${UnRegisterExtension} macro deletes the
; whole extension key when no backup_val exists, so we open-code the same
; backup-restore logic here for both scopes to avoid that footgun.
${If} $InstallMode = 1
  ; All-users install: associations live in HKCR (writes redirect to HKLM\Software\Classes).
  DeleteRegKey HKCR "PythonSCAD_File"
  DeleteRegKey HKCR "PythonSCAD_Python_File"
  ReadRegStr $0 HKCR ".scad" ""
  StrCmp $0 "PythonSCAD_File" 0 scad_not_ours
    ReadRegStr $1 HKCR ".scad" "backup_val"
    StrCmp $1 "" 0 +3
      ; No backup — remove just the default value we set, not the whole key.
      DeleteRegValue HKCR ".scad" ""
      Goto scad_not_ours
    WriteRegStr HKCR ".scad" "" $1
    DeleteRegValue HKCR ".scad" "backup_val"
  scad_not_ours:
  ReadRegStr $0 HKCR ".py" ""
  StrCmp $0 "PythonSCAD_Python_File" 0 py_not_ours
    ReadRegStr $1 HKCR ".py" "backup_val"
    StrCmp $1 "" 0 +3
      ; No backup — remove just the default value we set, not the whole key.
      DeleteRegValue HKCR ".py" ""
      Goto py_not_ours
    WriteRegStr HKCR ".py" "" $1
    DeleteRegValue HKCR ".py" "backup_val"
  py_not_ours:
${Else}
  ; Per-user install: associations live in HKCU\Software\Classes.
  DeleteRegKey HKCU "Software\Classes\PythonSCAD_File"
  DeleteRegKey HKCU "Software\Classes\PythonSCAD_Python_File"
  ReadRegStr $0 HKCU "Software\Classes\.scad" ""
  StrCmp $0 "PythonSCAD_File" 0 scad_cu_not_ours
    ReadRegStr $1 HKCU "Software\Classes\.scad" "backup_val"
    StrCmp $1 "" 0 +3
      ; No backup — remove just the default value we set, not the whole key.
      DeleteRegValue HKCU "Software\Classes\.scad" ""
      Goto scad_cu_not_ours
    WriteRegStr HKCU "Software\Classes\.scad" "" $1
    DeleteRegValue HKCU "Software\Classes\.scad" "backup_val"
  scad_cu_not_ours:
  ReadRegStr $0 HKCU "Software\Classes\.py" ""
  StrCmp $0 "PythonSCAD_Python_File" 0 py_cu_not_ours
    ReadRegStr $1 HKCU "Software\Classes\.py" "backup_val"
    StrCmp $1 "" 0 +3
      ; No backup — remove just the default value we set, not the whole key.
      DeleteRegValue HKCU "Software\Classes\.py" ""
      Goto py_cu_not_ours
    WriteRegStr HKCU "Software\Classes\.py" "" $1
    DeleteRegValue HKCU "Software\Classes\.py" "backup_val"
  py_cu_not_ours:
${EndIf}

; Remove the App Paths registry entries written at install time.
!define /ifndef APPPATHS_UN "Software\Microsoft\Windows\CurrentVersion\App Paths\pythonscad.exe"
${If} $InstallMode = 1
  DeleteRegKey HKLM "${APPPATHS_UN}"
${Else}
  DeleteRegKey HKCU "${APPPATHS_UN}"
${EndIf}

; Remove the openscad.lnk compatibility shim created at install time.
Delete "$INSTDIR\openscad.lnk"

; Remove the root Start Menu shortcut added by extra-install-commands.
; The MUI_PAGE_STARTMENU shortcuts under $STARTMENU_FOLDER are removed by the
; CPack template's own uninstall section, so we only clean up our additions here.
Delete "$SMPROGRAMS\@CPACK_PACKAGE_NAME@.lnk"

${RefreshShellIcons}
