; Unregister file associations scope-aware, mirroring the install logic.
; $InstallMode: 1 = all users (HKLM), 0 = current user (HKCU).
${If} $InstallMode = 1
  ; All-users install: ${UnRegisterExtension} operates on HKCR.
  ${UnRegisterExtension} ".scad" "PythonSCAD_File"
  ; Legacy cleanup: delete the stale OpenSCAD_File ProgID key left by older PythonSCAD
  ; installers, but do NOT call ${UnRegisterExtension} which would also touch the .scad
  ; default value (possibly re-removing what PythonSCAD_File just restored).
  DeleteRegKey HKCR "OpenSCAD_File"
  ${UnRegisterExtension} ".py" "PythonSCAD_Python_File"
${Else}
  ; Per-user install: remove handler keys and restore any backed-up extension defaults.
  ; Only remove the values we wrote — never DeleteRegKey the extension key, as it may
  ; contain subkeys (e.g. OpenWithProgids) or values written by other programs.
  DeleteRegKey HKCU "Software\Classes\PythonSCAD_File"
  DeleteRegKey HKCU "Software\Classes\PythonSCAD_Python_File"
  ReadRegStr $0 HKCU "Software\Classes\.scad" ""
  StrCmp $0 "PythonSCAD_File" 0 scad_not_ours
    ReadRegStr $1 HKCU "Software\Classes\.scad" "backup_val"
    StrCmp $1 "" 0 +3
      ; No backup — remove just the default value we set, not the whole key.
      DeleteRegValue HKCU "Software\Classes\.scad" ""
      Goto scad_not_ours
    WriteRegStr HKCU "Software\Classes\.scad" "" $1
    DeleteRegValue HKCU "Software\Classes\.scad" "backup_val"
  scad_not_ours:
  ReadRegStr $0 HKCU "Software\Classes\.py" ""
  StrCmp $0 "PythonSCAD_Python_File" 0 py_not_ours
    ReadRegStr $1 HKCU "Software\Classes\.py" "backup_val"
    StrCmp $1 "" 0 +3
      ; No backup — remove just the default value we set, not the whole key.
      DeleteRegValue HKCU "Software\Classes\.py" ""
      Goto py_not_ours
    WriteRegStr HKCU "Software\Classes\.py" "" $1
    DeleteRegValue HKCU "Software\Classes\.py" "backup_val"
  py_not_ours:
${EndIf}

; Remove the App Paths registry entries written at install time.
!define APPPATHS_UN "Software\Microsoft\Windows\CurrentVersion\App Paths\pythonscad.exe"
${If} $InstallMode = 1
  DeleteRegKey HKLM "${APPPATHS_UN}"
${Else}
  DeleteRegKey HKCU "${APPPATHS_UN}"
${EndIf}

; Remove the root Start Menu shortcut added by extra-install-commands.
; The MUI_PAGE_STARTMENU shortcuts under $STARTMENU_FOLDER are removed by the
; CPack template's own uninstall section, so we only clean up our additions here.
Delete "$SMPROGRAMS\PythonSCAD.lnk"

${RefreshShellIcons}
