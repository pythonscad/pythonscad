!define ARP "Software\Microsoft\Windows\CurrentVersion\Uninstall\@CPACK_PACKAGE_INSTALL_REGISTRY_KEY@"

; Persist install mode so the uninstaller knows whether to elevate.
; All-users: write to HKLM so any account can read it during uninstall.
; Per-user: write to HKCU.
${If} $MultiUser.InstallMode = 1
  WriteRegStr HKLM "Software\PythonSCAD" "InstallMode" "AllUsers"
${Else}
  WriteRegStr HKCU "Software\PythonSCAD" "InstallMode" "CurrentUser"
${EndIf}

; Calculate and store installed size in the appropriate registry hive
${GetSize} "$INSTDIR" "/S=0K" $0 $1 $2
IntFmt $0 "0x%08X" $0
${If} $MultiUser.InstallMode = 1
  WriteRegDWORD HKLM "${ARP}" "EstimatedSize" "$0"
${Else}
  WriteRegDWORD HKCU "${ARP}" "EstimatedSize" "$0"
${EndIf}

; Register file associations (SHCTX = HKLM or HKCU depending on SetShellVarContext)
${RegisterExtension} "$INSTDIR\pythonscad.exe" ".scad" "PythonSCAD_File"
${RegisterExtension} "$INSTDIR\pythonscad.exe" ".py" "PythonSCAD_Python_File"

; Add an extra shortcut directly in the Start Menu root for discoverability.
; The CPack template's MUI_PAGE_STARTMENU already creates the main shortcut
; under $SMPROGRAMS\$STARTMENU_FOLDER, so we only add the root-level alias here.
CreateShortCut "$SMPROGRAMS\PythonSCAD.lnk" "$INSTDIR\pythonscad.exe" "" "$INSTDIR\pythonscad.exe" 0

${RefreshShellIcons}
