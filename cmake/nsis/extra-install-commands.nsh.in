!define ARP "Software\Microsoft\Windows\CurrentVersion\Uninstall\@CPACK_PACKAGE_INSTALL_REGISTRY_KEY@"

; Persist install mode under the ARP uninstall key in the appropriate hive.
; Storing it there (rather than a separate Software\PythonSCAD key) ensures
; it lives in the same hive as the uninstall entry and cannot conflict between
; a per-user and an all-users install on the same machine.
${If} $MultiUser.InstallMode = 1
  WriteRegStr HKLM "${ARP}" "InstallMode" "AllUsers"
${Else}
  WriteRegStr HKCU "${ARP}" "InstallMode" "CurrentUser"
${EndIf}

; Register file associations scope-aware:
; - All-users installs use HKCR (via ${RegisterExtension}) which requires admin
;   rights that are already granted at this point.
; - Per-user installs write to HKCU\Software\Classes which takes precedence over
;   HKCR for the current user on Vista+ without requiring elevation.
${If} $MultiUser.InstallMode = 1
  ${RegisterExtension} "$INSTDIR\pythonscad.exe" ".scad" "PythonSCAD_File"
  ${RegisterExtension} "$INSTDIR\pythonscad.exe" ".py" "PythonSCAD_Python_File"
${Else}
  ; Back up any existing user extension defaults before overwriting, mirroring
  ; the backup_val pattern in mingw-file-association.nsh, so uninstall can restore them.
  ReadRegStr $0 HKCU "Software\Classes\.scad" ""
  StrCmp "$0" "" +2
  StrCmp "$0" "PythonSCAD_File" +2
    WriteRegStr HKCU "Software\Classes\.scad" "backup_val" "$0"
  WriteRegStr HKCU "Software\Classes\.scad" "" "PythonSCAD_File"
  WriteRegStr HKCU "Software\Classes\PythonSCAD_File" "" "PythonSCAD_File"
  WriteRegStr HKCU "Software\Classes\PythonSCAD_File\shell\open\command" "" '"$INSTDIR\pythonscad.exe" "%1"'
  WriteRegStr HKCU "Software\Classes\PythonSCAD_File\DefaultIcon" "" "$INSTDIR\pythonscad.exe,0"
  ReadRegStr $0 HKCU "Software\Classes\.py" ""
  StrCmp "$0" "" +2
  StrCmp "$0" "PythonSCAD_Python_File" +2
    WriteRegStr HKCU "Software\Classes\.py" "backup_val" "$0"
  WriteRegStr HKCU "Software\Classes\.py" "" "PythonSCAD_Python_File"
  WriteRegStr HKCU "Software\Classes\PythonSCAD_Python_File" "" "PythonSCAD_Python_File"
  WriteRegStr HKCU "Software\Classes\PythonSCAD_Python_File\shell\open\command" "" '"$INSTDIR\pythonscad.exe" "%1"'
  WriteRegStr HKCU "Software\Classes\PythonSCAD_Python_File\DefaultIcon" "" "$INSTDIR\pythonscad.exe,0"
${EndIf}

; Add an extra shortcut directly in the Start Menu root for discoverability.
; The CPack template's MUI_PAGE_STARTMENU already creates the main shortcut
; under $SMPROGRAMS\$STARTMENU_FOLDER, so we only add the root-level alias here.
CreateShortCut "$SMPROGRAMS\PythonSCAD.lnk" "$INSTDIR\pythonscad.exe" "" "$INSTDIR\pythonscad.exe" 0

${RefreshShellIcons}
